# HIM - Her Intelligent Mate Environment Variables
# Please update these values with your actual credentials

# --- SUPABASE CONFIGURATION ---
# Found in: Project Settings -> API
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- AI & VOICE CONFIGURATION ---
# ElevenLabs API Key: Found in Profile Settings -> API Key
EXPO_PUBLIC_ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ElevenLabs Agent ID: (Currently agent_9101kp14nztefgw986jp2kkyg07f)
EXPO_PUBLIC_ELEVENLABS_AGENT_ID=agent_9101kp14nztefgw986jp2kkyg07f

# Google Gemini API Key: Found in Google AI Studio
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key

# --- NOTIFICATION CONFIGURATION ---
# Expo Push Token Configuration (if needed)
EXPO_PUBLIC_PROJECT_ID=your_expo_project_id

# --- FEATURE FLAGS ---
EXPO_PUBLIC_ENABLE_VOICE=true
EXPO_PUBLIC_ENABLE_OFFLINE_SYNC=true
